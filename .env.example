# Active Storage Provider: 'minio', 's3', or 'local'
STORAGE_PROVIDER=minio

# Local Vault Storage directory (active only when STORAGE_PROVIDER=local)
LOCAL_STORAGE_DIR=./local_vault_storage

# MinIO Connection Settings (active when STORAGE_PROVIDER=minio)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=blackhole
MINIO_SECURE=false
MINIO_PUBLIC_URL=http://localhost:9000 # remap host for browser-direct presigned URLs

# AWS S3 Configuration Settings (active when STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET_NAME=your_s3_bucket_name
AWS_REGION=us-east-1

# Metadata Ledger (Supabase Database connection)
SUPABASE_URL=https://your-supabase-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# Groq AI Cloud Services API connection
GROQ_API_KEY=gsk_your_groq_api_key
